Package: dsHPCClient
Type: Package
Title: DataSHIELD Client for Durable Federated Job Runtime
Version: 0.1.0
Authors@R: c(
    person("David", "Sarrat González", role = c("aut", "cre"), email = "david.sarrat@isglobal.org"),
    person("Juan R", "González", role = "aut", email = "juanr.gonzalez@isglobal.org"))
Description: Client-side DataSHIELD package for composing and orchestrating
    durable federated jobs. Backend-agnostic control plane with adapters
    for Opal (via opalr) and Armadillo (via MolgenisArmadillo). Provides
    generic step constructors for session-plane and artifact-plane operations.
    Domain-specific DSLs live in upstream packages.
License: MIT + file LICENSE
Encoding: UTF-8
Depends:
    R (>= 4.1.0)
Imports:
    uuid,
    stats,
    DSI,
    digest,
    jsonlite
Suggests:
    opalr,
    DSOpal,
    MolgenisArmadillo,
    DSMolgenisArmadillo,
    testthat (>= 3.0.0),
    withr,
    DSLite
Config/testthat/edition: 3
